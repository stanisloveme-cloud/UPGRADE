// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum EventStatus {
  draft
  published
  archived
}

enum SpeakerRole {
  moderator
  speaker
}

enum SpeakerStatus {
  confirmed
  pre_confirmed
  contact
  to_contact
  declined
  review
}

enum PresenceStatus {
  planned
  onsite
  missing
}

// ============================================================
// MODELS
// ============================================================

model Event {
  id          Int         @id @default(autoincrement())
  name        String      @db.VarChar(255)
  description String?     @db.Text
  startDate     DateTime    @map("start_date") @db.Date
  endDate       DateTime    @map("end_date") @db.Date
  status        EventStatus @default(draft)
  memoTemplate  String?     @map("memo_template") @db.Text
  createdAt     DateTime    @default(now()) @map("created_at")

  halls    Hall[]
  users    UserEvent[]
  sponsors Sponsor[]

  @@map("events")
}

model Hall {
  id        Int    @id @default(autoincrement())
  eventId   Int    @map("event_id")
  name      String @db.VarChar(100)
  capacity  Int    @default(0)
  sortOrder Int    @default(0) @map("sort_order")

  event  Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tracks Track[]

  @@map("halls")
}

model Track {
  id          Int      @id @default(autoincrement())
  hallId      Int      @map("hall_id")
  name        String   @db.VarChar(255)
  description String?  @db.Text
  day         DateTime @db.Date
  startTime   String   @map("start_time") @db.VarChar(5) // "HH:MM"
  endTime     String   @map("end_time") @db.VarChar(5) // "HH:MM"
  sortOrder   Int      @default(0) @map("sort_order")

  // Announcement Metadata
  materialType  String?   @map("material_type") @db.VarChar(100)
  readyDate     DateTime? @map("ready_date") @db.Date
  status        String    @default("planned") @db.VarChar(50)
  materialLink  String?   @map("material_link") @db.VarChar(512)

  hall     Hall        @relation(fields: [hallId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@map("tracks")
}

model Session {
  id          Int     @id @default(autoincrement())
  trackId     Int     @map("track_id")
  name        String  @db.VarChar(255)
  description String? @db.Text
  startTime   String  @map("start_time") @db.VarChar(5) // "HH:MM"
  endTime     String  @map("end_time") @db.VarChar(5) // "HH:MM"
  comments    String? @db.Text
  clients     String? @db.Text
  managerId   Int?    @map("manager_id")

  track     Track             @relation(fields: [trackId], references: [id], onDelete: Cascade)
  manager   User?             @relation(fields: [managerId], references: [id], onDelete: SetNull)
  speakers  SessionSpeaker[]
  questions SessionQuestion[]
  briefings Briefing[]
  updatedAt DateTime          @default(now()) @updatedAt @map("updated_at")

  @@map("sessions")
}

model Speaker {
  id              Int     @id @default(autoincrement())
  firstName       String  @map("first_name") @db.VarChar(100)
  lastName        String  @map("last_name") @db.VarChar(100)
  company         String? @db.VarChar(255)
  position        String? @db.VarChar(255)
  email           String? @db.VarChar(255)
  phone           String? @db.VarChar(50)
  telegram        String? @db.VarChar(100)
  photoUrl        String? @map("photo_url") @db.VarChar(512)
  isSponsor       Boolean @default(false) @map("is_sponsor")
  bio             String? @db.Text
  internalComment String? @map("internal_comment") @db.Text

  // Assistant/Secretary Contact (Not part of Gold ID)
  hasAssistant     Boolean @default(false) @map("has_assistant")
  assistantName    String? @map("assistant_name") @db.VarChar(100)
  assistantContact String? @map("assistant_contact") @db.VarChar(255)

  sessions           SessionSpeaker[]
  moderatedBriefings Briefing[]

  @@map("speakers")
}

model SessionSpeaker {
  id              Int             @id @default(autoincrement())
  sessionId       Int             @map("session_id")
  speakerId       Int             @map("speaker_id")
  role            SpeakerRole     @default(speaker)
  status          SpeakerStatus   @default(review)
  statusDate      DateTime?       @map("status_date") @db.Date
  sortOrder       Int             @default(0) @map("sort_order")
  needsZoom       Boolean         @default(false) @map("needs_zoom")
  hasPresentation Boolean         @default(false) @map("has_presentation")
  managerComment    String?         @map("manager_comment") @db.Text
  programThesis     String?         @map("program_thesis") @db.Text
  newsletterQuote   String?         @map("newsletter_quote") @db.Text
  presenceStatus    PresenceStatus? @map("presence_status")

  notifiedTg        Boolean         @default(false) @map("notified_tg")
  notifiedEmail     Boolean         @default(false) @map("notified_email")
  memoHash          String?         @unique @default(uuid()) @map("memo_hash") @db.VarChar(36)

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker Speaker @relation(fields: [speakerId], references: [id], onDelete: Cascade)

  // Snapshots for historical accuracy
  companySnapshot   String? @map("company_snapshot") @db.VarChar(255)
  positionSnapshot  String? @map("position_snapshot") @db.VarChar(255)
  presentationTitle String? @map("presentation_title") @db.VarChar(255)
  presentationUrl   String? @map("presentation_url") @db.VarChar(512)

  @@unique([sessionId, speakerId])
  @@map("session_speakers")
}

model SessionQuestion {
  id        Int     @id @default(autoincrement())
  sessionId Int     @map("session_id")
  order     Int
  title     String  @db.VarChar(255)
  body      String? @db.Text

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_questions")
}

model Briefing {
  id          Int      @id @default(autoincrement())
  sessionId   Int      @map("session_id")
  moderatorId Int?     @map("moderator_id")
  datetime    DateTime @db.Timestamptz
  isDone      Boolean  @default(false) @map("is_done")
  link        String?  @db.VarChar(512)
  comment     String?  @db.Text

  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  moderator Speaker? @relation(fields: [moderatorId], references: [id], onDelete: SetNull)

  @@map("briefings")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(255)
  password     String   @db.VarChar(255)
  firstName    String?  @map("first_name") @db.VarChar(100)
  lastName     String?  @map("last_name") @db.VarChar(100)
  email        String?  @unique @db.VarChar(255)
  resetToken   String?  @unique @map("reset_token") @db.VarChar(255)
  resetTokenExpiry DateTime? @map("reset_token_expiry")
  role         String   @default("user") @db.VarChar(50)
  isSuperAdmin      Boolean  @default(false) @map("is_super_admin")
  isActive          Boolean  @default(true) @map("is_active")
  canManageSpeakers Boolean  @default(false) @map("can_manage_speakers")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  events           UserEvent[]
  assignedSessions Session[]

  @@map("users")
}

model UserEvent {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  eventId   Int      @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("user_events")
}

model Sponsor {
  id                     Int      @id @default(autoincrement())
  eventId                Int      @map("event_id")
  name                   String   @db.VarChar(255)
  shortDescription       String?  @map("short_description") @db.VarChar(255)
  websiteUrl             String?  @map("website_url") @db.VarChar(255)
  publicEmail            String?  @map("public_email") @db.VarChar(100)
  publicPhone            String?  @map("public_phone") @db.VarChar(50)
  logoUrl                String?  @map("logo_url") @db.VarChar(512)
  description            String?  @db.Text
  catalogDescription     String?  @map("catalog_description") @db.Text
  serviceCardDescription String?  @map("service_card_description") @db.Text
  marketSegments         Json?    @map("market_segments")
  city                   String?  @db.VarChar(100)
  employeeCount          Int?     @map("employee_count")
  annualTurnover         String?  @map("annual_turnover") @db.VarChar(100)
  telegram               String?  @db.VarChar(100)
  whatsapp               String?  @db.VarChar(100)
  contactName            String?  @map("contact_name") @db.VarChar(100)
  contactEmail           String?  @map("contact_email") @db.VarChar(100)
  cfoName                String?  @map("cfo_name") @db.VarChar(100)
  cfoPhone               String?  @map("cfo_phone") @db.VarChar(50)
  cfoEmail               String?  @map("cfo_email") @db.VarChar(100)
  cases                  Json?
  materialsUrl           String?  @map("materials_url") @db.VarChar(512)
  
  approvalHash           String?  @unique @default(uuid()) @map("approval_hash") @db.VarChar(36)
  status                 String   @default("pending") @db.VarChar(50) // pending, approved, rejected
  rejectionReason        String?  @map("rejection_reason") @db.Text

  createdAt              DateTime @default(now()) @map("created_at")

  event                  Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("sponsors")
}
