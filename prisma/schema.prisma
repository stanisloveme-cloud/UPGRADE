generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Event {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(255)
  description  String?
  startDate    DateTime       @map("start_date") @db.Date
  endDate      DateTime       @map("end_date") @db.Date
  status       EventStatus    @default(draft)
  createdAt    DateTime       @default(now()) @map("created_at")
  memoTemplate String?        @map("memo_template")
  sponsors     EventSponsor[]
  halls        Hall[]
  users        UserEvent[]

  @@map("events")
}

model Hall {
  id        Int     @id @default(autoincrement())
  eventId   Int     @map("event_id")
  name      String  @db.VarChar(100)
  capacity  Int     @default(0)
  sortOrder Int     @default(0) @map("sort_order")
  event     Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tracks    Track[]

  @@map("halls")
}

model Track {
  id           Int       @id @default(autoincrement())
  hallId       Int       @map("hall_id")
  name         String    @db.VarChar(255)
  description  String?
  day          DateTime  @db.Date
  startTime    String    @map("start_time") @db.VarChar(5)
  endTime      String    @map("end_time") @db.VarChar(5)
  sortOrder    Int       @default(0) @map("sort_order")
  materialLink String?   @map("material_link") @db.VarChar(512)
  materialType String?   @map("material_type") @db.VarChar(100)
  readyDate    DateTime? @map("ready_date") @db.Date
  status       String    @default("planned") @db.VarChar(50)
  sessions     Session[]
  hall         Hall      @relation(fields: [hallId], references: [id], onDelete: Cascade)

  @@map("tracks")
}

model Session {
  id          Int               @id @default(autoincrement())
  trackId     Int               @map("track_id")
  name        String            @db.VarChar(255)
  description String?
  startTime   String            @map("start_time") @db.VarChar(5)
  endTime     String            @map("end_time") @db.VarChar(5)
  comments    String?
  clients     String?
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at")
  managerId   Int?              @map("manager_id")
  briefings   Briefing[]
  questions   SessionQuestion[]
  speakers    SessionSpeaker[]
  manager     User?             @relation(fields: [managerId], references: [id])
  track       Track             @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Speaker {
  id                 Int              @id @default(autoincrement())
  firstName          String           @map("first_name") @db.VarChar(100)
  lastName           String           @map("last_name") @db.VarChar(100)
  company            String?          @db.VarChar(255)
  position           String?          @db.VarChar(255)
  email              String?          @db.VarChar(255)
  phone              String?          @db.VarChar(50)
  telegram           String?          @db.VarChar(100)
  photoUrl           String?          @map("photo_url") @db.VarChar(512)
  isSponsor          Boolean          @default(false) @map("is_sponsor")
  bio                String?
  internalComment    String?          @map("internal_comment")
  assistantContact   String?          @map("assistant_contact") @db.VarChar(255)
  assistantName      String?          @map("assistant_name") @db.VarChar(100)
  hasAssistant       Boolean          @default(false) @map("has_assistant")
  moderatedBriefings Briefing[]
  sessions           SessionSpeaker[]

  @@map("speakers")
}

model SessionSpeaker {
  id                    Int             @id @default(autoincrement())
  sessionId             Int             @map("session_id")
  speakerId             Int             @map("speaker_id")
  role                  SpeakerRole     @default(speaker)
  status                SpeakerStatus   @default(review)
  statusDate            DateTime?       @map("status_date") @db.Timestamptz(6)
  sortOrder             Int             @default(0) @map("sort_order")
  needs_zoom            Boolean         @default(false) @map("needs_call")
  hasPresentation       Boolean         @default(false) @map("has_presentation")
  managerComment        String?         @map("manager_comment")
  programThesis         String?         @map("program_thesis")
  newsletterQuote       String?         @map("newsletter_quote")
  presenceStatus        PresenceStatus? @map("presence_status")
  companySnapshot       String?         @map("company_snapshot") @db.VarChar(255)
  positionSnapshot      String?         @map("position_snapshot") @db.VarChar(255)
  presentationTitle     String?         @map("presentation_title") @db.VarChar(255)
  presentationUrl       String?         @map("presentation_url") @db.VarChar(512)
  presentationUpdatedAt DateTime?       @map("presentation_updated_at") @db.Timestamptz(6)
  memoHash              String?         @unique @default(uuid()) @map("memo_hash") @db.VarChar(36)
  notifiedEmail         Boolean         @default(false) @map("notified_email")
  notifiedTg            Boolean         @default(false) @map("notified_tg")
  statusUserId          Int?            @map("status_user_id")
  exportToWebsite       Boolean         @default(true) @map("export_to_website")
  session               Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  speaker               Speaker         @relation(fields: [speakerId], references: [id], onDelete: Cascade)
  statusUser            User?           @relation(fields: [statusUserId], references: [id])

  @@unique([sessionId, speakerId])
  @@map("session_speakers")
}

model SessionQuestion {
  id        Int     @id @default(autoincrement())
  sessionId Int     @map("session_id")
  order     Int
  title     String  @db.VarChar(255)
  body      String?
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_questions")
}

model Briefing {
  id          Int      @id @default(autoincrement())
  sessionId   Int      @map("session_id")
  moderatorId Int?     @map("moderator_id")
  datetime    DateTime @db.Timestamptz(6)
  isDone      Boolean  @default(false) @map("is_done")
  link        String?  @db.VarChar(512)
  comment     String?
  moderator   Speaker? @relation(fields: [moderatorId], references: [id])
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("briefings")
}

model User {
  id                Int              @id @default(autoincrement())
  username          String           @unique @db.VarChar(255)
  password          String           @db.VarChar(255)
  role              String           @default("user") @db.VarChar(50)
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")
  isSuperAdmin      Boolean          @default(false) @map("is_super_admin")
  canManageSpeakers Boolean          @default(false) @map("can_manage_speakers")
  email             String?          @unique @db.VarChar(255)
  firstName         String?          @map("first_name") @db.VarChar(100)
  isActive          Boolean          @default(true) @map("is_active")
  lastName          String?          @map("last_name") @db.VarChar(100)
  resetToken        String?          @unique @map("reset_token") @db.VarChar(255)
  resetTokenExpiry  DateTime?        @map("reset_token_expiry")
  sessionSpeakers   SessionSpeaker[]
  assignedSessions  Session[]
  sponsors          Sponsor[]
  events            UserEvent[]

  @@map("users")
}

model UserEvent {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  eventId   Int      @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("user_events")
}

model Sponsor {
  id                     Int              @id @default(autoincrement())
  name                   String           @db.VarChar(255)
  shortDescription       String?          @map("short_description") @db.VarChar(255)
  websiteUrl             String?          @map("website_url") @db.VarChar(255)
  publicEmail            String?          @map("public_email") @db.VarChar(100)
  publicPhone            String?          @map("public_phone") @db.VarChar(50)
  logoUrl                String?          @map("logo_url") @db.VarChar(512)
  description            String?
  catalogDescription     String?          @map("catalog_description")
  serviceCardDescription String?          @map("service_card_description")
  city                   String?          @db.VarChar(100)
  employeeCount          Int?             @map("employee_count")
  annualTurnover         String?          @map("annual_turnover") @db.VarChar(100)
  telegram               String?          @db.VarChar(100)
  whatsapp               String?          @db.VarChar(100)
  contactName            String?          @map("contact_name") @db.VarChar(100)
  contactEmail           String?          @map("contact_email") @db.VarChar(100)
  cfoName                String?          @map("cfo_name") @db.VarChar(100)
  cases                  Json?
  approvalHash           String?          @unique @default(uuid()) @map("approval_hash") @db.VarChar(36)
  status                 String           @default("pending") @db.VarChar(50)
  rejectionReason        String?          @map("rejection_reason")
  createdAt              DateTime         @default(now()) @map("created_at")
  assignedManagerId      Int?             @map("assigned_manager_id")
  exportToWebsite        Boolean          @default(false) @map("export_to_website")
  logoFileUrl            String?          @map("logo_file_url") @db.VarChar(512)
  events                 EventSponsor[]
  segments               SponsorSegment[]
  assignedManager        User?            @relation(fields: [assignedManagerId], references: [id])

  @@map("sponsors")
}

model EventSponsor {
  eventId   Int      @map("event_id")
  sponsorId Int      @map("sponsor_id")
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sponsor   Sponsor  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@id([eventId, sponsorId])
  @@map("event_sponsors")
}

model MarketSegment {
  id        Int              @id @default(autoincrement())
  name      String           @unique @db.VarChar(255)
  parentId  Int?             @map("parent_id")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  parent    MarketSegment?   @relation("SegmentHierarchy", fields: [parentId], references: [id])
  children  MarketSegment[]  @relation("SegmentHierarchy")
  sponsors  SponsorSegment[]

  @@map("market_segments")
}

model SponsorSegment {
  sponsorId       Int           @map("sponsor_id")
  marketSegmentId Int           @map("market_segment_id")
  marketSegment   MarketSegment @relation(fields: [marketSegmentId], references: [id], onDelete: Cascade)
  sponsor         Sponsor       @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@id([sponsorId, marketSegmentId])
  @@map("sponsor_segments")
}

enum EventStatus {
  draft
  published
  archived
}

enum SpeakerRole {
  moderator
  speaker
}

enum SpeakerStatus {
  confirmed
  pre_confirmed
  contact
  to_contact
  declined
  review
}

enum PresenceStatus {
  planned
  onsite
  missing
}
