2026-03-13T20:52:16.7579798Z ##[group]Run appleboy/ssh-action@v1.0.3
2026-03-13T20:52:16.7580099Z with:
2026-03-13T20:52:16.7580365Z   host: ***
2026-03-13T20:52:16.7580570Z   username: ***
2026-03-13T20:52:16.7582243Z   key: ***
2026-03-13T20:52:16.7582466Z   envs: COMPOSE_CONFIG,PROMETHEUS_CONFIG
2026-03-13T20:52:16.7594835Z   script: # Stop on first error
set -e

# Export variables for docker-compose
export DOCKER_USERNAME=***

# Login to Docker Hub to avoid rate limits
echo "***" | docker login -u "***" --password-stdin

# Pull the latest images
docker pull ***/upgrade-backend:latest
docker pull ***/upgrade-frontend:latest

# Create project directory
mkdir -p ~/upgrade-crm
cd ~/upgrade-crm

# Remove directory prometheus.yml if it was created by docker daemon by mistake
if [ -d "prometheus.yml" ]; then
    rm -rf prometheus.yml
fi

# Write config file directly (Single Source of Truth)
echo "$COMPOSE_CONFIG" > docker-compose.prod.yml
echo "$PROMETHEUS_CONFIG" > prometheus.yml

# DEBUG: Verify config file content
echo "=== DOCKER COMPOSE CONFIG ==="
cat docker-compose.prod.yml

# Restart services using new images
# Prioritize 'docker compose' (v2)
if docker compose version &> /dev/null; then
    DC_CMD="docker compose"
elif command -v docker-compose &> /dev/null; then
    DC_CMD="docker-compose"
else
    echo "Error: Docker Compose not found"
    exit 1
fi
$DC_CMD -f docker-compose.prod.yml down || true
docker ps -a --filter "name=upgrade-crm" -q | xargs -r docker rm -f || true

# Install certbot if not present
if ! command -v certbot &> /dev/null; then
    sudo apt-get update
    sudo apt-get install -y certbot
fi

# Check and run Certbot before bringing containers up
if [ ! -d "/etc/letsencrypt/live/devupgrade.***.ru" ]; then
    echo "Certificates not found. Generating via certbot standalone..."
    sudo certbot certonly --standalone -d devupgrade.***.ru --non-interactive --agree-tos -m dev@***.ru
fi

# Setup cron for certbot renewal if not exists
if ! sudo crontab -l | grep -q "certbot renew"; then
    (sudo crontab -l 2>/dev/null; echo "0 3 * * * certbot renew --pre-hook \"cd ~/upgrade-crm && docker compose -f docker-compose.prod.yml stop frontend\" --post-hook \"cd ~/upgrade-crm && docker compose -f docker-compose.prod.yml start frontend\"") | sudo crontab -
fi

$DC_CMD -f docker-compose.prod.yml up -d --remove-orphans --force-recreate

# NOTE: Migrations run automatically inside NestJS on startup (PrismaService.onModuleInit)
# No need to docker compose exec separately — that was causing exit 137 (SIGKILL)

# Prune unused images
docker image prune -f

# DEBUG: Show running containers and logs
echo "=== RUNNING CONTAINERS ==="
docker ps -a

echo "=== NGINX CONFIG CHECKSUM ==="
$DC_CMD -f docker-compose.prod.yml exec -T frontend cat /etc/nginx/conf.d/default.conf

echo "=== FRONTEND LOGS ==="
docker logs -n 20 upgrade-crm-frontend-1 || docker logs -n 20 upgrade-crm_frontend_1 || echo "Container name prediction failed"

echo "=== BACKEND LOGS ==="
docker logs -n 50 upgrade-crm-app-1 || docker logs -n 50 upgrade-crm_app_1 || echo "Container name prediction failed"

